using System.IO.Ports;
using Spectre.Console;

// --- CONFIGURATION ---
string portName = "COM5"; // <--- CHANGE THIS to your Arduino Port
int score = 0;
int activeMole = -1;
string status = "Waiting for Arduino...";
bool[] moleStates = new bool[6];

// --- SERIAL SETUP ---
using SerialPort sp = new SerialPort(portName, 9600);
try
{
    sp.DataReceived += (s, e) => {
        string data = sp.ReadLine().Trim();
        if (data.StartsWith("P:"))
        {
            activeMole = int.Parse(data.Split(':')[1]);
            status = $"Mole {activeMole + 1} popped up!";
        }
        else if (data.StartsWith("H:"))
        {
            score = int.Parse(data.Split(':')[1]);
            status = "[green]WHACKED![/]";
            activeMole = -1;
        }
        else if (data == "M")
        {
            status = "[red]MISSED![/]";
            activeMole = -1;
        }
    };
    sp.Open();
}
catch
{
    AnsiConsole.MarkupLine($"[red]Error:[/] Could not open {portName}. Check COM port in code.");
    return;
}

// --- UI RENDER LOOP ---
await AnsiConsole.Live(new Rule())
    .StartAsync(async ctx => {
        while (true)
        {
            var grid = new Grid().AddColumns(3);

            // Build the Mole Grid
            for (int i = 0; i < 6; i++)
            {
                bool isActive = (activeMole == i);
                var panel = new Panel(isActive ? "[yellow] (O_O) [/]\n[yellow]  UP!  [/]" : "[grey] ( . ) [/]\n[grey]      [/]")
                    .Header($"Mole {i + 1}")
                    .BorderColor(isActive ? Color.Yellow : Color.Grey);

                moleStates[i] = isActive;
                if (i == 2) grid.AddRow(new Panel[] { }); // dummy to force next row if needed
            }

            // Manually adding rows for a 2x3 layout
            grid.AddRow(CreateMolePanel(0), CreateMolePanel(1), CreateMolePanel(2));
            grid.AddEmptyRow();
            grid.AddRow(CreateMolePanel(3), CreateMolePanel(4), CreateMolePanel(5));

            var layout = new Table()
                .Title("[bold cyan]WHACK-A-MOLE: ULTIMATE CONSOLE[/]")
                .AddColumn("Dashboard")
                .AddRow(new Panel(grid).Header("GAME FIELD").BorderColor(Color.Blue))
                .AddRow(new Columns(
                    new Panel($"[bold yellow]SCORE:[/] {score}").Expand(),
                    new Panel($"[bold]STATUS:[/] {status}").Expand()
                ))
                .Expand();

            ctx.UpdateTarget(layout);
            await Task.Delay(50); // Refresh at 20fps
        }
    });

// Helper to style panels
Panel CreateMolePanel(int id)
{
    bool isActive = (activeMole == id);
    return new Panel(isActive ? "[bold yellow]  (0_0)  [/]\n[bold yellow] HIT ME! [/]" : "[grey]  ( - )  [/]\n[grey]  HIDDEN [/]")
        .BorderColor(isActive ? Color.Yellow : Color.Black)
        .Header($"Hole {id + 1}");
}